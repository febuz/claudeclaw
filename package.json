{
  "name": "@fillslava/claudeclaw",
  "version": "0.1.0",
  "description": "Multi-agent orchestration system for Claude Code + Anthropic agents",
  "type": "module",
  "bin": {
    "claudeclaw": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc && chmod +x dist/cli.js",
    "start": "node dist/cli.js",
    "test": "vitest",
    "lint": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "mcp:researcher": "tsx src/mcp-servers/researcher-mcp.ts",
    "mcp:skills": "tsx src/mcp-servers/skills-mcp.ts",
    "codex:executor": "tsx src/codex/executor.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "dotenv": "^16.3.1",
    "node-cache": "^5.1.2",
    "pino": "^8.17.0",
    "yargs": "^17.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/yargs": "^17.0.35",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
